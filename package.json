{
  "name": "baubesprechungs-manager",
  "version": "1.5.0",
  "description": "BBM - Baubesprechungsmanager",
  "author": "Steffen Bandholt",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "npm run fix:electron-deps && npm run start:raw",
    "start:raw": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "pack": "electron-builder --dir",
    "dist": "node scripts/dist.cjs",
    "test": "node scripts/runElectronNodeTest.cjs",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "fix:electron-deps": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "test:node": "node scripts/test.cjs"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1"
  },
  "dependencies": {
    "archiver": "^5.3.2",
    "better-sqlite3": "^12.6.2",
    "extract-zip": "^2.0.1",
    "pdfjs-dist": "^4.10.38",
    "ui-editor-kit": "github:SteffenBandholt/UI-Editor-kit#fcd1782243379bfca2ed53ece285ef288412c0b5",
    "yauzl": "^3.2.1"
  },
  "build": {
    "appId": "de.bbm.baubesprechungsmanager",
    "productName": "BBM",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "uiEditor/**/*",
      "package.json",
      "build/bbm-icon.ico",
      "!src/main/db/app.db",
      "!**/backups/**",
      "!**/*.db",
      "!**/*.sqlite",
      "!**/*.sqlite3"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "dev/tools/whisper.cpp/Release",
        "to": "audio/whisper",
        "filter": [
          "whisper-cli.exe",
          "whisper-server.exe",
          "*.dll"
        ]
      },
      {
        "from": "dev/tools/ffmpeg",
        "to": "audio/ffmpeg",
        "filter": [
          "ffmpeg.exe"
        ]
      },
      {
        "from": "dev/models",
        "to": "audio/models",
        "filter": [
          "ggml-small.bin"
        ]
      }
    ],
    "win": {
      "icon": "build/bbm-icon.ico",
      "target": [
        "nsis"
      ],
      "fileAssociations": [
        {
          "ext": "bbmlic",
          "name": "BBM Lizenzdatei",
          "description": "BBM Lizenzdatei"
        }
      ]
    },
    "nsis": {
      "installerIcon": "build/nsis-icon.ico",
      "uninstallerIcon": "build/nsis-icon.ico",
      "installerHeaderIcon": "build/nsis-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BBM"
    }
  }
}
